# ============================================================================
#  ALFRED kiosk env. Copy to `.env` and fill in. `.env` is gitignored.
# ============================================================================

# ---- Secrets — server-side ONLY (used by server/proxy.mjs, never the browser)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
SONIOX_API_KEY=xxxxxxxx
# Optional proxy tuning
# PORT=8787
# LLM_MODEL=claude-haiku-4-5
# SONIOX_TEMP_KEY_TTL=300

# ---- UI build-time (VITE_*, shipped in the bundle — no secrets here) ----
# Which floor THIS Alfred serves: 1 or 2 (2F: use `npm run dev:2f` / `build:2f`)
VITE_FLOOR=1
# Default language: ko | en | ja | zh
VITE_DEFAULT_LANG=ko
# Browser → proxy base. Default /api (same origin via the Vite dev/preview proxy)
VITE_API_BASE=/api
# Soniox real-time model
VITE_SONIOX_MODEL=stt-rt-v4
# true = run fully offline with mock STT/LLM (no keys / proxy needed)
VITE_USE_MOCKS=false

# ---- ros_bridge → Turtlebot4 laptop (FMS request channel, IF-01) ----
# Change ONLY the host (IP) when it moves — the whole ws:// URL derives from it.
# IP of the laptop wired to the Turtlebot4 (runs Nav2). Empty = mock FMS.
VITE_ROSBRIDGE_HOST=
# rosbridge port (default 9090).
VITE_ROSBRIDGE_PORT=9090
# (advanced) full URL override — wins over HOST/PORT when set. Usually blank.
# VITE_ROSBRIDGE_URL=ws://192.168.0.42:9090
# Topic the IF-01 requests (ESCORT / CANCEL / INTERACTING) publish to.
VITE_ROS_INFO_TOPIC=/information
# ROS message type advertised for that topic (rosbridge needs it to publish).
# Default std_msgs/String ships the IF-01 JSON as text in .data (no custom .msg).
# Set a custom type (e.g. alfred_msgs/Information) to send structured fields.
VITE_ROS_INFO_MSG_TYPE=std_msgs/String
# ROS topic(s) for YOLO emergency detections (fire / injured / suspicious),
# comma-separated. The kiosk subscribes and shows a full-screen alert (ver03).
# 1F kiosk: /robot2/detection/info  |  2F kiosk: /robot4/detection/info
# detector_node publishes JSON: { "event_type": "FIRE"|"INJURED_PERSON"|"SUSPICIOUS_PERSON", ... }
VITE_DETECTION_TOPIC=/robot2/detection/info
# Inbound robot-state (IF-02 / ui_state) topic — see 로봇상태_UI연동_계약.md.
# Auto-derived from VITE_FLOOR: /robot2/ui_state (1F) · /robot4/ui_state (2F).
# Publisher: alfred_bridge/escort_state_bridge_node emits the UI states
#   (ESCORT_1F / WAITING_1F / DOCKING / PATROL …) as std_msgs/String JSON on
#   /robotN/ui_state — run it:  ros2 run alfred_bridge escort_state_bridge_node
# Leave EMPTY to use the auto-derived topic; set only to override.
VITE_ROBOT_STATE_TOPIC=
