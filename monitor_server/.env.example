# Local ROS2->Supabase bridge configuration.
# Copy to .env and `set -a; source .env; set +a` before `python3 main.py`.

# Storage backend: "sqlite" (local Flask dashboard) or "supabase" (cloud pump).
FMS_BACKEND=supabase

# Supabase project (Project Settings > API).
# Use the SERVICE ROLE key here — it stays on this LAN PC, never in the browser.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY
SUPABASE_TIMEOUT=8.0

# Offline threshold used by the dashboard (must match supabase-config.js statusTimeout).
FMS_STATUS_TIMEOUT=10.0
